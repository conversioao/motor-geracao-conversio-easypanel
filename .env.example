# Variaveis de Ambiente - Backend Conversio.AO (Easypanel)
# Copie este ficheiro para .env no painel do Easypanel

NODE_ENV=production
PORT=3001

# URL publico do backend (para callbacks do n8n)
PUBLIC_URL=https://SEU-DOMINIO-API.easypanel.host

# URL do frontend na Vercel (necessario para CORS)
FRONTEND_URL=https://SEU-APP.vercel.app

# PostgreSQL
DB_HOST=IP-DO-SEU-POSTGRES
DB_PORT=5432
DB_USER=postgres
DB_PASS=SUA-PASSWORD
DB_NAME=conversioao

# Seguranca JWT
JWT_SECRET=CHAVE-SECRETA-MINIMO-32-CARACTERES

# Armazenamento S3 (Contabo)
S3_ENDPOINT=https://usc1.contabostorage.com
S3_ACCESS_KEY=SEU-ACCESS-KEY
S3_SECRET_KEY=SEU-SECRET-KEY
S3_BUCKET=kwikdocsao
S3_REGION=us-central-1

# OpenAI
OPENAI_API_KEY=sk-proj-SEU-KEY

# Webhooks n8n
N8N_GENERATE_WEBHOOK=https://SEU-N8N.easypanel.host/webhook/conversio-ai-generate
N8N_VIDEO_WEBHOOK=https://SEU-N8N.easypanel.host/webhook/conversio-ai-generate-video
N8N_VOICE_WEBHOOK=https://SEU-N8N.easypanel.host/webhook/conversio-ai-generate-voice
N8N_WEBHOOK_SECRET=SEU-WEBHOOK-SECRET

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=SEU-GOOGLE-CLIENT-ID
